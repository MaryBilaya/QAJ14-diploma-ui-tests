  "homepage": "https://github.com/MaryBilaya/playwright-ui-tests-diploma#readme",
  "bugs": {
    "url": "https://github.com/MaryBilaya/playwright-ui-tests-diploma/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaryBilaya/playwright-ui-tests-diploma.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "format": "npx prettier --write .",
    "pw:registr": "npx playwright test --grep '@registration'",
    "allure:clear": "rmdir /S /Q allure-results 2>nul & rmdir /S /Q allure-report 2>nul",
    "allure:history": "powershell -Command \"if (Test-Path 'allure-report/history') { if (!(Test-Path 'allure-results')) { New-Item -ItemType Directory -Path 'allure-results' | Out-Null }; Copy-Item 'allure-report/history' 'allure-results/history' -Recurse -Force }\"",
    "allure:report": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.1",
    "allure-commandline": "^2.36.0",
    "allure-playwright": "^3.4.5",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "playwright": "^1.58.2"
  }
}
